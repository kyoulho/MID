{
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    // 강타입의 엄격 모드 활성화
    "noImplicitAny": true,
    // 암시적인 any 타입 방지
    "strictNullChecks": true,
    // null과 undefined에 대한 엄격한 체크
    "strictFunctionTypes": true,
    // 함수 타입에 대한 엄격한 검사를 적용
    "strictBindCallApply": true,
    // bind, call, apply에 대한 타입 검사를 엄격하게
    "strictPropertyInitialization": true,
    // 클래스 프로퍼티의 초기화 확인
    "noImplicitThis": true,
    // 암시적인 this 타입 방지
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": "."
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
