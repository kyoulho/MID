{
  "extends": [
    // Next.js 권장 규칙
    "next/core-web-vitals",
    // TypeScript 권장 규칙
    "plugin:@typescript-eslint/recommended",
    // import 순서 및 정리 권장 규칙
    "plugin:import/recommended",
    "plugin:import/typescript",
    // 접근성 관련 규칙
    "plugin:jsx-a11y/recommended"
  ],
  "plugins": [
    "@typescript-eslint",
    "import",
    "jsx-a11y"
  ],
  "rules": {
    "@typescript-eslint/explicit-module-boundary-types": "off",
    // 모듈 경계 유형을 명시하지 않아도 됨
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    // 사용하지 않는 변수 경고, "_"로 시작하는 변수는 무시
    "import/order": [
      "error",
      {
        "groups": [
          "builtin",
          "external",
          "internal",
          "parent",
          "sibling",
          "index"
        ],
        // import 그룹 순서
        "newlines-between": "always",
        "alphabetize": {
          "order": "asc",
          "caseInsensitive": true
        }
        // 알파벳 순서로 정렬
      }
    ],
    "import/no-unresolved": "error",
    "jsx-a11y/anchor-is-valid": [
      "error",
      {
        "components": [
          "Link"
        ],
        // Next.js Link 컴포넌트를 올바르게 사용하도록 설정
        "specialLink": [
          "hrefLeft",
          "hrefRight"
        ],
        "aspects": [
          "invalidHref",
          "preferButton"
        ]
      }
    ]
  },
  "settings": {
    "import/resolver": {
      "typescript": {}
      // TypeScript 경로 설정을 인식
    }
  }
}
